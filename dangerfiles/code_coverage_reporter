# path the get report file generated by Kover
kover_report = "**/build/reports/kover/reportDebug.xml"
# iterate over all the report files and add them to the shroud report
Dir[kover_report].each do |file_name|
  shroud.reportKover(
    moduleName: "#{file_name.split('/').first} module",
    file: file_name,
    failIfUnderProjectThreshold: false,
    totalProjectThreshold: 85
  )
end
